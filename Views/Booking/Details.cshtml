@model Eventease.Models.BookingModel

@{
    ViewData["Title"] = "Booking Details";
}

<h1>Booking Details</h1>

<div>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">Booking Name</dt>
        <dd class="col-sm-10">@Model.BookingName</dd>

        <dt class="col-sm-2">Venue</dt>
        <dd class="col-sm-10">@Model.Venue?.venueName</dd>

        <dt class="col-sm-2">Event</dt>
        <dd class="col-sm-10">@Model.Event?.EventName</dd>

        <dt class="col-sm-2">Booking Date</dt>
        <dd class="col-sm-10">@Model.BookingDate.ToString("yyyy-MM-dd")</dd>
    </dl>
</div>

<a asp-action="Edit" asp-route-id="@Model.BookingId" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>
