@model Eventease.Models.VenueModel

@{
    ViewData["Title"] = "Delete Venue";
}

<h1>Delete Venue</h1>

<h3>Are you sure you want to delete this venue?</h3>

<hr />

<dl class="row">

    <dt class="col-sm-2">Venue Name</dt>
    <dd class="col-sm-10">@Model.venueName</dd>

    <dt class="col-sm-2">Location</dt>
    <dd class="col-sm-10">@Model.venueLocation</dd>

    <dt class="col-sm-2">Capacity</dt>
    <dd class="col-sm-10">@Model.venueCapacity</dd>

</dl>

<form asp-action="Delete">

    <input type="hidden" asp-for="venueId" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>

</form>